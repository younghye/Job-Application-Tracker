{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0.1",
  "permissions": ["storage", "sidePanel", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Open Job Application Tracker"
  }
}
