{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0",
  "permissions": ["webNavigation", "storage", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.seek.com.au/*",
    "https://*.seek.co.nz/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Open Job Tracker"
  }
}
